rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper para verificar se o usuário está autenticado e é dono do dado
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Regras para a coleção de Pastas
    match /folders/{folderId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }
    
    // Regras para a coleção de Documentos
    match /documents/{docId} {
      allow read, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }
    
    // Regras para a coleção de Notificações
    match /notifications/{notifId} {
      allow list: if request.auth != null && request.query.limit <= 20;
      allow get, update, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
    }

    // Comentário para forçar redeploy e garantir permissões de listagem (queries)
    // Salt: force_redeploy_notifications_v5_final
  }
}