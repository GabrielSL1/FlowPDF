rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permissão total para usuários autenticados durante o desenvolvimento
    // Isso garante que o app nunca trave por "Missing or insufficient permissions"
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // Comentário para forçar redeploy imediato e limpar cache de permissões antigo
    // deploy_v105_unlimited_access_for_auth_users
  }
}