rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper para verificar se o usuário está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }

    // Regras genéricas para dados do usuário
    // Permite qualquer operação se o usuário estiver logado e for o dono do dado
    match /folders/{folderId} {
      allow read, write: if isAuthenticated() && (
        (resource == null && request.resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }
    
    match /documents/{docId} {
      allow read, write: if isAuthenticated() && (
        (resource == null && request.resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }
    
    match /notifications/{notifId} {
      allow read, write: if isAuthenticated() && (
        (resource == null && request.resource.data.userId == request.auth.uid) ||
        (resource != null && resource.data.userId == request.auth.uid)
      );
    }

    // Salt para forçar redeploy e limpar cache de permissões do Firestore
    // force_redeploy_v15_final_permissions_fix
  }
}