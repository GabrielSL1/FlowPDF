rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // OBS: o motor de regras do Firestore não consegue provar a seguranca de uma consulta
    // (list/query) quando a condição usa "campo is list" antes de um "in" — ele nega a
    // consulta inteira com "permission-denied" mesmo que o resultado devesse ser permitido.
    // Por isso o "sharedWith is list" foi removido; os dados sempre gravam sharedWith como
    // array (mesmo vazio), então a checagem extra era redundante.

    // OBS 2: campos opcionais (sharedWith) podem não existir em documentos/pastas
    // antigos criados antes desse campo existir. Comparar "email in <campo ausente>"
    // gera erro de tipo nas Rules e derruba a consulta inteira — por isso todo
    // acesso a "sharedWith" usa o acessor .get(campo, []), que retorna uma lista
    // vazia (segura para "in") quando o campo não existe.

    // OBS 3: o motor de Security Rules nega a consulta de "list" inteira em
    // "documents" quando a regra de leitura depende de QUALQUER get()/exists()
    // em outra coleção (ex: checar isPublic ou sharedWith da pasta via get()),
    // mesmo que nenhum documento realmente combine com a query e mesmo usando
    // apenas uma checagem. Por isso a regra de "documents" NUNCA acessa a
    // coleção "folders" — tudo que ela precisa (isPublic e sharedWith da pasta
    // no momento do upload) é gravado diretamente no documento (campos
    // "folderIsPublic" e "folderSharedWith").

    function isOwner(data) {
      return request.auth != null && data.userId == request.auth.uid;
    }

    // ---- folders ----
    match /folders/{folderId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        resource.data.isPublic == true ||
        request.auth.token.email in resource.data.get('sharedWith', [])
      );
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data);
      allow delete: if isOwner(resource.data) || resource.data.isPublic == true;
    }

    // ---- documents ----
    match /documents/{docId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        request.auth.token.email in resource.data.get('sharedWith', []) ||
        resource.data.folderIsPublic == true ||
        request.auth.token.email in resource.data.get('folderSharedWith', [])
      );
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isOwner(resource.data) || resource.data.folderIsPublic == true;
    }

    // ---- members (lista compartilhada da equipe) ----
    match /members/{memberId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.addedBy == request.auth.uid;
      allow delete: if request.auth != null && resource.data.addedBy == request.auth.uid;
      allow update: if false;
    }

    // ---- notifications ----
    match /notifications/{notifId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        resource.data.isPublic == true ||
        request.auth.token.email in resource.data.sharedWith
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        resource.data.isPublic == true ||
        request.auth.token.email in resource.data.sharedWith
      );
      allow delete: if false;
    }
  }
}
