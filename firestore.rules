rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper para verificar se o usuário está autenticado e é dono do dado
    function isOwner(data) {
      return request.auth != null && data.userId == request.auth.uid;
    }

    // Regras para a coleção de Pastas
    match /folders/{folderId} {
      allow read, update, delete: if isOwner(resource.data);
      allow create: if isOwner(request.resource.data);
    }
    
    // Regras para a coleção de Documentos
    match /documents/{docId} {
      allow read, update, delete: if isOwner(resource.data);
      allow create: if isOwner(request.resource.data);
    }
    
    // Regras para a coleção de Notificações
    match /notifications/{notifId} {
      allow read, update: if isOwner(resource.data);
      allow delete: if isOwner(resource.data);
      allow create: if isOwner(request.resource.data);
    }

    // Comentário para forçar redeploy e garantir permissões de listagem (queries)
    // Salt: fix_notifications_list_v4
  }
}